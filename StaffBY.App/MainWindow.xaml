<Window x:Class="StaffBY.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:StaffBY.App.Views.UserControls"
        Title="StaffBY - Автоматизация кадрового делопроизводства"
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="StaffBY" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text=" | Кадровый учет" FontSize="14" Foreground="#BDC3C7" Margin="5,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock x:Name="UserInfoText" Text="Пользователь: " Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="Выйти" Click="LogoutButton_Click" Background="#E74C3C" Foreground="White" Padding="10,5" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" x:Name="MainTabControl" Margin="10">
            <TabItem Header="🏢 Организация">
                <uc:OrganizationControl x:Name="OrganizationControl"/>
            </TabItem>
            <TabItem Header="📋 Сотрудники">
                <uc:EmployeesControl x:Name="EmployeesControl"/>
            </TabItem>
            <TabItem Header="🏢 Штатное расписание">
                <uc:PositionsControl x:Name="PositionsControl"/>
            </TabItem>
            <TabItem Header="🏖️ Отпуска">
                <uc:VacationsControl x:Name="VacationsControl"/>
            </TabItem>
            <TabItem Header="📅 Табель">
                <uc:TimesheetControl x:Name="TimesheetControl"/>
            </TabItem>
            <TabItem Header="💰 Начисление ЗП">
                <uc:AccrualsControl x:Name="AccrualsControl"/>
            </TabItem>
            <TabItem Header="💸 Выплата ЗП">
                <uc:PaymentControl x:Name="PaymentControl"/>
            </TabItem>
            <TabItem Header="📄 Документы">
                <uc:DocumentsControl x:Name="DocumentsControl"/>
            </TabItem>
            <TabItem Header="📊 Отчеты">
                <uc:ReportsControl x:Name="ReportsControl"/>
            </TabItem>
            <TabItem Header="📦 Архив">
                <uc:ArchiveControl x:Name="ArchiveControl"/>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2" Background="#ECF0F1">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов к работе"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>