<!-- StaffBY.App/Views/MainWindow.xaml -->
<Window x:Class="StaffBY.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StaffBY - Автоматизация кадрового делопроизводства"
        Height="750" 
        Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Стиль для заголовков разделов -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <!-- Стиль для кнопок -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== Верхняя панель ========== -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="StaffBY" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" | Кадровый учет" 
                               FontSize="14" 
                               Foreground="#BDC3C7"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock x:Name="UserInfoText" 
                               Text="Пользователь: " 
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <Button Content="Выйти" 
                            Click="LogoutButton_Click"
                            Background="#E74C3C"
                            Foreground="White"
                            Padding="10,5"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== Основной контент с вкладками ========== -->
        <TabControl Grid.Row="1" x:Name="MainTabControl" Margin="10">

            <!-- Вкладка 1: Организация -->
            <TabItem Header="🏢 Организация">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Реквизиты организации" 
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Полное наименование:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="txtFullName" Margin="5,0"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Сокращенное наименование:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="txtShortName" Margin="5,0"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="УНП:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="txtUNP" Margin="5,0"/>
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Юридический адрес:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="txtAddress" Margin="5,0"/>
                    </Grid>

                    <Grid Grid.Row="5" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Директор (ФИО):" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="cmbDirector" 
                                  DisplayMemberPath="FullName"
                                  SelectedValuePath="Id"
                                  Margin="5,0"/>
                    </Grid>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20">
                        <Button Content="💾 Сохранить" Width="100" Height="30" Margin="5"
                                Background="#27AE60" Foreground="White"
                                Click="SaveOrganizationButton_Click"/>
                        <Button Content="🔄 Обновить" Width="100" Height="30" Margin="5"
                                Background="#3498DB" Foreground="White"
                                Click="RefreshOrganizationButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Сотрудники -->
            <TabItem Header="📋 Сотрудники">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Управление сотрудниками" 
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="SearchTextBox" 
                                 Width="250" 
                                 Padding="8"
                                 ToolTip="Поиск по ФИО или табельному номеру"
                                 TextChanged="SearchTextBox_TextChanged"/>
                        <Button Content="🔍 Поиск" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="SearchButton_Click"/>
                        <Button Content="➕ Добавить сотрудника" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="AddEmployeeButton_Click"/>
                        <Button Content="📊 Экспорт в Excel" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="ExportToExcelButton_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="EmployeesDataGrid" 
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              IsReadOnly="True"
                              MouseDoubleClick="EmployeesDataGrid_MouseDoubleClick"
                              AlternatingRowBackground="#F9F9F9"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Табельный номер" 
                                                Binding="{Binding PersonalNumber}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Фамилия" 
                                                Binding="{Binding LastName}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Имя" 
                                                Binding="{Binding FirstName}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Отчество" 
                                                Binding="{Binding Patronymic}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Должность" 
                                                Binding="{Binding PositionName}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="Отдел" 
                                                Binding="{Binding DepartmentName}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="Дата рождения" 
                                                Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Телефон" 
                                                Binding="{Binding Phone}" 
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 3: Штатное расписание -->
            <TabItem Header="🏢 Штатное расписание">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Штатное расписание" 
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Добавить должность" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="AddPositionButton_Click"/>
                        <Button Content="✏️ Редактировать" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="EditPositionButton_Click"/>
                        <Button Content="🗑️ Удалить" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="DeletePositionButton_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="PositionsDataGrid" 
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Должность" 
                                                Binding="{Binding Name}" 
                                                Width="200"/>
                            <DataGridTextColumn Header="Отдел" 
                                                Binding="{Binding DepartmentName}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="Количество ставок" 
                                                Binding="{Binding NumberOfPositions}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Оклад (руб.)" 
                                                Binding="{Binding Salary, StringFormat=N2}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Надбавка (руб.)" 
                                                Binding="{Binding Allowance, StringFormat=N2}" 
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 4: Отпуска -->
            <TabItem Header="🏖️ Отпуска">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Управление отпусками" 
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Добавить отпуск" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="AddVacationButton_Click"/>
                        <Button Content="📅 График отпусков" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="VacationScheduleButton_Click"/>
                        <ComboBox x:Name="YearComboBox" 
                                  Width="100" 
                                  Margin="10,0,0,0"
                                  SelectionChanged="YearComboBox_SelectionChanged"/>
                    </StackPanel>

                    <DataGrid x:Name="VacationsDataGrid" 
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Сотрудник" 
                                                Binding="{Binding EmployeeFullName}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="Вид отпуска" 
                                                Binding="{Binding VacationType}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Дата начала" 
                                                Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Дата окончания" 
                                                Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Количество дней" 
                                                Binding="{Binding DaysCount}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Основание" 
                                                Binding="{Binding Basis}" 
                                                Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 5: Табель -->
            <TabItem Header="📅 Табель">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Табель учета рабочего времени" 
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="dpTimesheetStart" Width="120" Margin="0,0,10,0"/>
                        <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="dpTimesheetEnd" Width="120" Margin="0,0,10,0"/>
                        <Button Content="📊 Сформировать табель" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="GenerateTimesheetButton_Click"/>
                        <Button Content="📎 Импорт из Excel" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="ImportTimesheetButton_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Учет рабочего времени" 
                               FontWeight="Bold" Margin="0,10,0,5"/>

                    <DataGrid x:Name="TimesheetDataGrid" 
                              Grid.Row="3"
                              AutoGenerateColumns="False"
                              AlternatingRowBackground="#F9F9F9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Табельный номер" Binding="{Binding PersonalNumber}" Width="100"/>
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding FullName}" Width="150"/>
                            <DataGridTextColumn Header="Отработано дней" Binding="{Binding WorkedDays}" Width="120"/>
                            <DataGridTextColumn Header="Больничные" Binding="{Binding SickDays}" Width="100"/>
                            <DataGridTextColumn Header="Отпуск" Binding="{Binding VacationDays}" Width="100"/>
                            <DataGridTextColumn Header="Прогулы" Binding="{Binding AbsentDays}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 6: Начисление ЗП (для экономиста) -->
            <TabItem Header="💰 Начисление ЗП">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Расчет начислений заработной платы" 
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="dpPayrollStart" Width="120" Margin="0,0,10,0"/>
                        <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="dpPayrollEnd" Width="120" Margin="0,0,10,0"/>
                        <Button Content="🧮 Рассчитать начисления" 
                                Background="#3498DB" Foreground="White"
                                Padding="10,5" Click="CalculateAccrualsButton_Click"/>
                        <Button Content="📤 Экспорт в Excel" 
                                Background="#27AE60" Foreground="White"
                                Padding="10,5" Margin="10,0,0,0"
                                Click="ExportAccrualsButton_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Сводка по начислениям" 
                               FontWeight="Bold" Margin="0,5,0,5"/>

                    <DataGrid x:Name="AccrualsDataGrid" Grid.Row="3"
                              AutoGenerateColumns="False"
                              AlternatingRowBackground="#F9F9F9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Табельный номер" Binding="{Binding PersonalNumber}" Width="100"/>
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding FullName}" Width="150"/>
                            <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}" Width="150"/>
                            <DataGridTextColumn Header="Оклад" Binding="{Binding Salary, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="Отработано дней" Binding="{Binding WorkedDays}" Width="120"/>
                            <DataGridTextColumn Header="Начислено (руб.)" Binding="{Binding AccruedAmount, StringFormat=N2}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 7: Выплата ЗП (для бухгалтера) -->
            <TabItem Header="💸 Выплата ЗП">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Расчет заработной платы к выплате" 
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="dpPaymentStart" Width="120" Margin="0,0,10,0"/>
                        <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="dpPaymentEnd" Width="120" Margin="0,0,10,0"/>
                        <Button Content="🧮 Рассчитать к выплате" 
                                Background="#3498DB" Foreground="White"
                                Padding="10,5" Click="CalculatePaymentButton_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Расчетный листок" 
                               FontWeight="Bold" Margin="0,5,0,5"/>

                    <DataGrid x:Name="PaymentDataGrid" Grid.Row="3"
                              AutoGenerateColumns="False"
                              AlternatingRowBackground="#F9F9F9"
                              SelectionChanged="PaymentDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Табельный номер" Binding="{Binding PersonalNumber}" Width="100"/>
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding FullName}" Width="150"/>
                            <DataGridTextColumn Header="Начислено" Binding="{Binding AccruedAmount, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="Подоходный налог (13%)" Binding="{Binding IncomeTax, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="Взносы (1%)" Binding="{Binding Contributions, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="К выплате" Binding="{Binding NetAmount, StringFormat=N2}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="4" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,10,0,0" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtPaymentDetails" Text="Выберите сотрудника для просмотра деталей"/>
                            <Button Grid.Column="1" Content="🖨️ Печать расчетного листка" 
                                    Background="#3498DB" Foreground="White"
                                    Padding="10,5" Click="PrintPayslipButton_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка 8: Документы -->
            <TabItem Header="📄 Документы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Создание документов" 
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <ComboBox x:Name="DocumentTypeComboBox" 
                                  Width="200" 
                                  Margin="0,0,10,0">
                            <ComboBoxItem Content="Трудовой договор"/>
                            <ComboBoxItem Content="Приказ о приеме"/>
                            <ComboBoxItem Content="Приказ об увольнении"/>
                            <ComboBoxItem Content="Приказ об отпуске"/>
                        </ComboBox>

                        <ComboBox x:Name="EmployeeComboBox" 
                                  Width="200" 
                                  DisplayMemberPath="FullName"
                                  Margin="0,0,10,0"/>

                        <Button Content="📄 Сформировать документ" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="GenerateDocumentButton_Click"/>
                    </StackPanel>

                    <Border Grid.Row="2" 
                            BorderBrush="#BDC3C7" 
                            BorderThickness="1" 
                            Padding="10">
                        <ScrollViewer>
                            <TextBlock x:Name="DocumentPreviewText" 
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка 9: Отчеты -->
            <TabItem Header="📊 Отчеты">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Формирование отчетов" 
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="👥 Список сотрудников" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="EmployeeListReportButton_Click"/>
                        <Button Content="📈 Движение кадров" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="PersonnelMovementReportButton_Click"/>
                        <Button Content="🎂 Дни рождения" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="BirthdaysReportButton_Click"/>
                        <Button Content="🏖️ Отчет по отпускам" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="VacationsReportButton_Click"/>
                        <Button Content="📋 Воинский учет" 
                                Style="{StaticResource ActionButtonStyle}"
                                Click="MilitaryReportButton_Click"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="2">
                        <TextBlock x:Name="ReportTextBlock" 
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Вкладка 10: Архив -->
            <TabItem Header="📦 Архив">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Уволенные сотрудники" 
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <DataGrid x:Name="ArchivedEmployeesDataGrid" 
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Табельный номер" 
                                                Binding="{Binding PersonalNumber}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Фамилия" 
                                                Binding="{Binding LastName}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Имя" 
                                                Binding="{Binding FirstName}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Должность" 
                                                Binding="{Binding PositionName}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="Дата увольнения" 
                                                Binding="{Binding DismissalDate, StringFormat=dd.MM.yyyy}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Причина" 
                                                Binding="{Binding DismissalReason}" 
                                                Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ========== Строка статуса ========== -->
        <StatusBar Grid.Row="2" Background="#ECF0F1">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов к работе"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="RecordCountText" Text="Записей: 0"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>