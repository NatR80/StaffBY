<Window x:Class="StaffBY.App.Views.FamilyMemberEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование члена семьи"
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- ФИО Label -->
            <RowDefinition Height="Auto"/>
            <!-- ФИО TextBox -->
            <RowDefinition Height="Auto"/>
            <!-- Степень родства Label -->
            <RowDefinition Height="Auto"/>
            <!-- Степень родства ComboBox -->
            <RowDefinition Height="Auto"/>
            <!-- Дата рождения Label -->
            <RowDefinition Height="Auto"/>
            <!-- Дата рождения DatePicker -->
            <RowDefinition Height="Auto"/>
            <!-- Место работы Label -->
            <RowDefinition Height="Auto"/>
            <!-- Место работы TextBox -->
            <RowDefinition Height="Auto"/>
            <!-- Документ Label -->
            <RowDefinition Height="Auto"/>
            <!-- Документ ComboBox -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Редактирование члена семьи"
                   FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" 
                   Margin="0,0,0,15"/>

        <!-- ФИО -->
        <TextBlock Grid.Row="1" Text="ФИО:" Margin="0,5,0,2"/>
        <TextBox Grid.Row="2" x:Name="txtFullName" Height="28" Margin="0,0,0,10"/>

        <!-- Степень родства -->
        <TextBlock Grid.Row="3" Text="Степень родства:" Margin="0,5,0,2"/>
        <ComboBox Grid.Row="4" x:Name="cmbRelationship" Height="28" Margin="0,0,0,10">
            <ComboBoxItem Content="Супруг/Супруга"/>
            <ComboBoxItem Content="Сын"/>
            <ComboBoxItem Content="Дочь"/>
            <ComboBoxItem Content="Отец"/>
            <ComboBoxItem Content="Мать"/>
            <ComboBoxItem Content="Брат"/>
            <ComboBoxItem Content="Сестра"/>
            <ComboBoxItem Content="Опекун"/>
            <ComboBoxItem Content="Иждивенец"/>
        </ComboBox>

        <!-- Дата рождения -->
        <TextBlock Grid.Row="5" Text="Дата рождения:" Margin="0,5,0,2"/>
        <DatePicker Grid.Row="6" x:Name="dpBirthDate" Height="28" Margin="0,0,0,10"
                    SelectedDateFormat="Short"/>

        <!-- Место работы, учебы -->
        <TextBlock Grid.Row="7" Text="Место работы, учебы:" Margin="0,5,0,2"/>
        <TextBox Grid.Row="8" x:Name="txtWorkPlace" Height="28" Margin="0,0,0,10"/>

        <!-- Документ -->
        <TextBlock Grid.Row="9" Text="Документ:" Margin="0,5,0,2"/>
        <ComboBox Grid.Row="10" x:Name="cmbDocument" Height="28" Margin="0,0,0,15"
                  IsEditable="True">
            <ComboBoxItem Content="Свидетельство о рождении"/>
            <ComboBoxItem Content="Паспорт"/>
            <ComboBoxItem Content="Справка с места учебы"/>
            <ComboBoxItem Content="Справка МСЭК"/>
            <ComboBoxItem Content="Удостоверение"/>
        </ComboBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
            <Button Content="💾 Сохранить" Width="90" Height="30" Margin="5"
                    Background="#27AE60" Foreground="White"
                    Click="SaveButton_Click"/>
            <Button Content="❌ Отмена" Width="90" Height="30" Margin="5"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>