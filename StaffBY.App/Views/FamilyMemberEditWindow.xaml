<Window x:Class="StaffBY.App.Views.FamilyMemberEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование члена семьи"
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Редактирование члена семьи" 
                   FontSize="16" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- ФИО -->
        <TextBlock Grid.Row="1" Text="Фамилия, Имя, Отчество:" Style="{StaticResource LabelStyle}"/>
        <TextBox Grid.Row="2" x:Name="txtFullName" Style="{StaticResource TextBoxStyle}"/>

        <!-- Степень родства -->
        <TextBlock Grid.Row="3" Text="Степень родства:" Style="{StaticResource LabelStyle}" Margin="5,15,5,5"/>
        <ComboBox Grid.Row="4" x:Name="cmbRelationship" Style="{StaticResource ComboBoxStyle}">
            <ComboBoxItem Content="Супруг(а)"/>
            <ComboBoxItem Content="Сын"/>
            <ComboBoxItem Content="Дочь"/>
            <ComboBoxItem Content="Отец"/>
            <ComboBoxItem Content="Мать"/>
            <ComboBoxItem Content="Брат"/>
            <ComboBoxItem Content="Сестра"/>
        </ComboBox>

        <!-- Год рождения -->
        <TextBlock Grid.Row="5" Text="Год рождения:" Style="{StaticResource LabelStyle}" Margin="5,15,5,5"/>
        <TextBox Grid.Row="6" x:Name="txtBirthYear" Style="{StaticResource TextBoxStyle}"/>

        <!-- Место работы -->
        <TextBlock Grid.Row="7" Text="Место работы:" Style="{StaticResource LabelStyle}" Margin="5,15,5,5"/>
        <TextBox Grid.Row="8" x:Name="txtWorkPlace" Style="{StaticResource TextBoxStyle}"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button x:Name="btnSave" 
                    Content="💾 Сохранить" 
                    Width="100" 
                    Height="35" 
                    Margin="5"
                    Background="#27AE60"
                    Foreground="White"
                    Click="SaveButton_Click"/>
            <Button x:Name="btnCancel" 
                    Content="❌ Отмена" 
                    Width="100" 
                    Height="35" 
                    Margin="5"
                    Click="CancelButton_Click"/>
        </StackPanel>

    </Grid>
</Window>