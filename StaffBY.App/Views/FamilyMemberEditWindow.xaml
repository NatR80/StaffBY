<Window x:Class="StaffBY.App.Views.FamilyMemberEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование члена семьи"
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Редактирование члена семьи" 
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- ФИО -->
        <TextBlock Grid.Row="1" Text="ФИО:" Margin="0,5,0,5"/>
        <TextBox Grid.Row="2" x:Name="txtFullName" Height="30" Margin="0,0,0,15"/>

        <!-- Степень родства -->
        <TextBlock Grid.Row="3" Text="Степень родства:" Margin="0,5,0,5"/>
        <ComboBox Grid.Row="4" x:Name="cmbRelationship" Height="30" Margin="0,0,0,15">
            <ComboBoxItem Content="Супруг/Супруга"/>
            <ComboBoxItem Content="Сын"/>
            <ComboBoxItem Content="Дочь"/>
            <ComboBoxItem Content="Отец"/>
            <ComboBoxItem Content="Мать"/>
            <ComboBoxItem Content="Брат"/>
            <ComboBoxItem Content="Сестра"/>
        </ComboBox>

        <!-- Год рождения -->
        <TextBlock Grid.Row="5" Text="Год рождения:" Margin="0,5,0,5"/>
        <TextBox Grid.Row="6" x:Name="txtBirthYear" Height="30" Margin="0,0,0,15"/>

        <!-- Место работы -->
        <TextBlock Grid.Row="7" Text="Место работы:" Margin="0,5,0,5"/>
        <TextBox Grid.Row="8" x:Name="txtWorkPlace" Height="30" Margin="0,0,0,15"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="💾 Сохранить" Width="100" Height="35" Margin="5"
                    Background="#27AE60" Foreground="White" Click="SaveButton_Click"/>
            <Button Content="❌ Отмена" Width="100" Height="35" Margin="5"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>