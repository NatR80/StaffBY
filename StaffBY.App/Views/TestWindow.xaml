<Window x:Class="StaffBY.App.Views.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тест авторизации" Height="250" Width="350"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Логин:" Margin="0,0,0,5"/>
        <TextBox x:Name="txtLogin" Height="30" Margin="0,0,0,15" Padding="5"/>

        <TextBlock Text="Пароль:" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtPassword" Height="30" Margin="0,0,0,20" Padding="5"/>

        <Button Content="Войти" Click="Login_Click" Height="35" Margin="0,0,0,20"/>
       
        <TextBlock x:Name="txtResult" Foreground="Red" TextWrapping="Wrap" TextAlignment="Center"/>
    </StackPanel>
</Window>