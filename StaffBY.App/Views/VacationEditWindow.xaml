<Window x:Class="StaffBY.App.Views.VacationEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление периода отпуска"
        Height="520" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📅 ПЕРИОД ОТПУСКА" 
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"
                   Foreground="#2C3E50"/>

        <!-- Период работы -->
        <TextBlock Grid.Row="1" Text="Период работы:" FontWeight="Bold" Margin="0,5,0,5"/>
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DatePicker x:Name="dpPeriodStart" Grid.Column="0" Height="30" SelectedDateChanged="PeriodStart_Changed"/>
            <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Center" Margin="10,0,10,0"/>
            <DatePicker x:Name="dpPeriodEnd" Grid.Column="2" Height="30" IsEnabled="False"/>
        </Grid>

        <!-- Основной и дополнительный (только для чтения) -->
        <Grid Grid.Row="3" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#3498DB" BorderThickness="2" CornerRadius="5" Padding="10" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Основной отпуск" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Grid.Row="1" x:Name="txtBasicDays" Text="24" FontSize="18" 
                               FontWeight="Bold" Foreground="#3498DB" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Text="дней" FontSize="12" 
                               VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,3"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="#27AE60" BorderThickness="2" CornerRadius="5" Padding="10" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Дополнительный отпуск" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Grid.Row="1" x:Name="txtAdditionalDays" Text="0" FontSize="18" 
                               FontWeight="Bold" Foreground="#27AE60" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Text="дней" FontSize="12" 
                               VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,3"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Всего отпуска -->
        <Border Grid.Row="4" Background="#ECF0F1" CornerRadius="5" Padding="10" Margin="0,10,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ВСЕГО отпуска:" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="txtTotalDays" Text="24" FontSize="22" 
                           FontWeight="Bold" Foreground="#E74C3C" Margin="10,0,5,0"/>
                <TextBlock Grid.Column="2" Text="дней" FontSize="14" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Предоставляется отпуск с (автоматически) -->
        <TextBlock Grid.Row="5" Text="Предоставляется отпуск с:" FontWeight="Bold" Margin="0,15,0,5"/>
        <DatePicker Grid.Row="6" x:Name="dpAvailableFrom" Height="30" IsEnabled="False" Background="#F0F0F0"/>

        <!-- График отпуска -->
        <TextBlock Grid.Row="7" Text="График отпуска:" FontWeight="Bold" Margin="0,15,0,5"/>
        <TextBox Grid.Row="8" x:Name="txtSchedule" Height="30" Padding="5"
                 ToolTip="Например: Июнь 2026 или Июнь/Июль 2026"/>

        <!-- Пояснение -->
        <TextBlock Grid.Row="9" Text="* По закону отпуск предоставляется через 6 месяцев после начала периода"
                   FontSize="10" Foreground="Gray" Margin="0,10,0,0"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="💾 Сохранить" Width="100" Height="35" Margin="5"
                    Background="#27AE60" Foreground="White" Click="SaveButton_Click"/>
            <Button Content="❌ Отмена" Width="100" Height="35" Margin="5"
                    Background="#95A5A6" Foreground="White" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>