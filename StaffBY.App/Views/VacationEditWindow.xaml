<Window x:Class="StaffBY.App.Views.VacationEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование отпуска"
        Height="520" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Редактирование отпуска" 
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Период работы -->
        <TextBlock Grid.Row="1" Text="Период работы:" FontWeight="Bold" Margin="0,5,0,5"/>
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DatePicker x:Name="dpPeriodStart" Grid.Column="0" Height="30"/>
            <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Center" Margin="10,0,10,0"/>
            <DatePicker x:Name="dpPeriodEnd" Grid.Column="2" Height="30"/>
        </Grid>

        <!-- Основной и дополнительный (только для чтения) -->
        <Grid Grid.Row="3" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Основной отпуск" FontWeight="Bold"/>
                    <TextBlock Grid.Row="1" x:Name="txtBasicDays" Text="24" FontSize="14"/>
                </Grid>
            </Border>
            <Border Grid.Column="1" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Дополнительный отпуск" FontWeight="Bold"/>
                    <TextBlock Grid.Row="1" x:Name="txtAdditionalDays" Text="0" FontSize="14"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Использовано дней -->
        <TextBlock Grid.Row="4" Text="Использовано дней:" Margin="0,10,0,5"/>
        <TextBox Grid.Row="5" x:Name="txtUsedDays" Height="30" TextChanged="UsedDays_TextChanged"/>

        <!-- Дата начала отпуска -->
        <TextBlock Grid.Row="6" Text="Дата начала отпуска:" Margin="0,15,0,5"/>
        <DatePicker Grid.Row="7" x:Name="dpStartDate" Height="30" SelectedDateChanged="StartDate_Changed"/>

        <!-- Дата окончания (рассчитывается автоматически) -->
        <TextBlock Grid.Row="8" Text="Дата окончания отпуска:" Margin="0,15,0,5"/>
        <TextBox Grid.Row="9" x:Name="txtEndDate" Height="30" IsReadOnly="True" Background="#F0F0F0"/>

        <!-- Основание -->
        <TextBlock Grid.Row="10" Text="Основание (Приказ):" Margin="0,15,0,5"/>
        <TextBox Grid.Row="11" x:Name="txtBasis" Height="30" Margin="0,0,0,15"/>

        <!-- График отпуска -->
        <TextBlock Grid.Row="12" Text="График отпуска:" Margin="0,5,0,5"/>
        <TextBox Grid.Row="13" x:Name="txtSchedule" Height="30" Margin="0,0,0,15"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="💾 Сохранить" Width="100" Height="35" Margin="5"
                    Background="#27AE60" Foreground="White" Click="SaveButton_Click"/>
            <Button Content="❌ Отмена" Width="100" Height="35" Margin="5"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>