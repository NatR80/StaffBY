<Window x:Class="StaffBY.App.Views.VacationEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование отпуска"
        Height="480" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style x:Key="DatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Редактирование отпуска" 
                   FontSize="16" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Вид отпуска -->
        <TextBlock Grid.Row="1" Text="Вид отпуска:" Style="{StaticResource LabelStyle}"/>
        <ComboBox Grid.Row="2" x:Name="cmbVacationType" Style="{StaticResource ComboBoxStyle}">
            <ComboBoxItem Content="Основной отпуск"/>
            <ComboBoxItem Content="Дополнительный отпуск"/>
            <ComboBoxItem Content="Социальный отпуск"/>
            <ComboBoxItem Content="Учебный отпуск"/>
            <ComboBoxItem Content="Отпуск без сохранения зарплаты"/>
        </ComboBox>

        <!-- За какой период -->
        <TextBlock Grid.Row="3" Text="За какой период (рабочий год):" Style="{StaticResource LabelStyle}" Margin="5,15,5,5"/>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DatePicker Grid.Column="0" x:Name="dpPeriodStart" Style="{StaticResource DatePickerStyle}"/>
            <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Center" Margin="5,0,5,0"/>
            <DatePicker Grid.Column="2" x:Name="dpPeriodEnd" Style="{StaticResource DatePickerStyle}"/>
        </Grid>

        <!-- Дата начала и окончания -->
        <TextBlock Grid.Row="5" Text="Дата отпуска:" Style="{StaticResource LabelStyle}" Margin="5,15,5,5"/>
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DatePicker Grid.Column="0" x:Name="dpStartDate" Style="{StaticResource DatePickerStyle}"/>
            <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Center" Margin="5,0,5,0"/>
            <DatePicker Grid.Column="2" x:Name="dpEndDate" Style="{StaticResource DatePickerStyle}"/>
        </Grid>

        <!-- Количество дней (рассчитывается автоматически) -->
        <TextBlock Grid.Row="7" Text="Количество дней:" Style="{StaticResource LabelStyle}" Margin="5,15,5,5"/>
        <TextBox Grid.Row="8" x:Name="txtDaysCount" Style="{StaticResource TextBoxStyle}" IsReadOnly="True" Background="#F0F0F0"/>

        <!-- Основание -->
        <TextBlock Grid.Row="9" Text="Основание (приказ):" Style="{StaticResource LabelStyle}" Margin="5,15,5,5"/>
        <TextBox Grid.Row="10" x:Name="txtBasis" Style="{StaticResource TextBoxStyle}" Height="60" TextWrapping="Wrap"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="11" Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button x:Name="btnSave" 
                    Content="💾 Сохранить" 
                    Width="100" 
                    Height="35" 
                    Margin="5"
                    Background="#27AE60"
                    Foreground="White"
                    Click="SaveButton_Click"/>
            <Button x:Name="btnCancel" 
                    Content="❌ Отмена" 
                    Width="100" 
                    Height="35" 
                    Margin="5"
                    Click="CancelButton_Click"/>
        </StackPanel>

    </Grid>
</Window>