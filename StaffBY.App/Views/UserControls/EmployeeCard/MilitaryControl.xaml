<UserControl x:Class="StaffBY.App.Views.UserControls.EmployeeCard.MilitaryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Категория учета -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Категория учета:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbMilitaryCategory" Height="28" Margin="5">
                <ComboBoxItem Content="I категория"/>
                <ComboBoxItem Content="II категория"/>
                <ComboBoxItem Content="Не подлежит"/>
            </ComboBox>

            <!-- Состав -->
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Состав:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox Grid.Row="0" Grid.Column="3" x:Name="cmbMilitaryComposition" Height="28" Margin="5">
                <ComboBoxItem Content="Солдаты"/>
                <ComboBoxItem Content="Сержанты"/>
                <ComboBoxItem Content="Прапорщики"/>
                <ComboBoxItem Content="Офицеры"/>
            </ComboBox>

            <!-- Воинское звание -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Воинское звание:" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtMilitaryRank" Height="28" Margin="5"/>

            <!-- ВУС -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="ВУС №:" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtMilitaryVUS" Height="28" Margin="5"/>

            <!-- Годность к ВС -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Годность к ВС:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbFitness" Height="28" Margin="5">
                <ComboBoxItem Content="А - годен"/>
                <ComboBoxItem Content="Б - годен с ограничениями"/>
                <ComboBoxItem Content="В - ограниченно годен"/>
                <ComboBoxItem Content="Г - временно не годен"/>
                <ComboBoxItem Content="Д - не годен"/>
            </ComboBox>

            <!-- Военкомат -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Военкомат:" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtMilitaryCommissariat" Height="28" Margin="5"/>

            <!-- Спец. учет -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="Спец. учет:" VerticalAlignment="Center" Margin="5"/>
            <CheckBox Grid.Row="5" Grid.Column="1" x:Name="chkSpecialRegistration" VerticalAlignment="Center" Margin="5"/>

            <!-- Моб. предписание -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Моб. предписание №:" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtMobilizationNumber" Height="28" Margin="5"/>

            <!-- Дата постановки -->
            <TextBlock Grid.Row="7" Grid.Column="0" Text="Дата постановки:" VerticalAlignment="Center" Margin="5"/>
            <DatePicker Grid.Row="7" Grid.Column="1" x:Name="dpRegistrationDate" Height="28" Margin="5"/>

            <!-- Снят с учета -->
            <TextBlock Grid.Row="8" Grid.Column="0" Text="Снят с учета:" VerticalAlignment="Center" Margin="5"/>
            <CheckBox Grid.Row="8" Grid.Column="1" x:Name="chkRemovedFromRegistry" VerticalAlignment="Center" Margin="5"/>

            <!-- Дата снятия -->
            <TextBlock Grid.Row="9" Grid.Column="0" Text="Дата снятия:" VerticalAlignment="Center" Margin="5"/>
            <DatePicker Grid.Row="9" Grid.Column="1" x:Name="dpRemovalDate" Height="28" Margin="5"/>
        </Grid>
    </ScrollViewer>
</UserControl>