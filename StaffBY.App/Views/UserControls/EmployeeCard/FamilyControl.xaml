<UserControl x:Class="StaffBY.App.Views.UserControls.EmployeeCard.FamilyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Первая строка: кнопки управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="➕ Добавить члена семьи" Padding="10,5"
                    Background="#3498DB" Foreground="White"
                    Click="AddFamilyMember_Click"/>
            <Button Content="🗑️ Удалить" Padding="10,5" Margin="5,0,0,0"
                    Background="#E74C3C" Foreground="White"
                    Click="RemoveFamilyMember_Click"/>
        </StackPanel>

        <!-- Вторая строка: Дети и иждивенцы -->
        <Border Grid.Row="1" Background="#F0F0F0" BorderBrush="#CCCCCC" 
                BorderThickness="1" CornerRadius="5" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Дети, иждивенцы:" 
                           VerticalAlignment="Center" FontWeight="Bold"/>

                <TextBox Grid.Column="1" x:Name="txtDependents" 
                         Height="30" Margin="10,0,0,0" 
                         Background="White" BorderBrush="#999" 
                         BorderThickness="1"
                         ToolTip="Укажите количество детей и иждивенцев"/>
            </Grid>
        </Border>

        <!-- Третья строка: таблица членов семьи -->
        <DataGrid x:Name="dgFamilyMembers" Grid.Row="2" 
                  AutoGenerateColumns="False" SelectionMode="Single"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="180"/>
                <DataGridTextColumn Header="Степень родства" Binding="{Binding Relationship}" Width="110"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat='dd.MM.yyyy'}" Width="100"/>
                <DataGridTextColumn Header="Место работы, учебы" Binding="{Binding WorkPlace}" Width="150"/>
                <DataGridTextColumn Header="Документ" Binding="{Binding Document}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>