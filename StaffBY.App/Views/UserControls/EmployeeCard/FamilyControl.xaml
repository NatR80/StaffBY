<UserControl x:Class="StaffBY.App.Views.UserControls.EmployeeCard.FamilyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="➕ Добавить члена семьи" Padding="10,5" 
                    Background="#3498DB" Foreground="White" Click="AddFamilyMember_Click"/>
            <Button Content="🗑️ Удалить" Padding="10,5" Margin="5,0,0,0"
                    Background="#E74C3C" Foreground="White" Click="RemoveFamilyMember_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgFamilyMembers" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Степень родства" Binding="{Binding Relationship}" Width="120"/>
                <DataGridTextColumn Header="Год рождения" Binding="{Binding BirthYear}" Width="80"/>
                <DataGridTextColumn Header="Место работы" Binding="{Binding WorkPlace}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>