<UserControl x:Class="StaffBY.App.Views.UserControls.EmployeeCard.EmploymentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:StaffBY.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- Конвертер для итогового оклада -->
        <converters:SalaryConverter x:Key="SalaryConverter"/>

        <!-- Стиль для группбоксов -->
        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Стиль для кнопок таблиц -->
        <Style x:Key="TableButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Стиль для read-only полей -->
        <Style x:Key="ReadOnlyTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- ============================================ -->
            <!-- ЛЕВАЯ КОЛОНКА (60%)                           -->
            <!-- ============================================ -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: Должность, Отдел -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1: Дата приема -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2: Оклад, Надбавка -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3: Итого оклад -->
                    <RowDefinition Height="Auto"/>
                    <!-- 4: Ставка, Часы -->
                    <RowDefinition Height="Auto"/>
                    <!-- 5: Разряд, Коэф -->
                    <RowDefinition Height="Auto"/>
                    <!-- 6: Интенсивность, Контракт -->
                    <RowDefinition Height="Auto"/>
                    <!-- 7: Форма, Тип договора -->
                    <RowDefinition Height="Auto"/>
                    <!-- 8: Срок действия -->
                    <RowDefinition Height="Auto"/>
                    <!-- 9: Стаж, Раб.неделя -->
                    <RowDefinition Height="Auto"/>
                    <!-- 10: Категория, Условия -->
                    <RowDefinition Height="Auto"/>
                    <!-- 11: Пенсионер, Инвалид -->
                    <RowDefinition Height="Auto"/>
                    <!-- 12: Дата увольнения -->
                    <RowDefinition Height="Auto"/>
                    <!-- 13: Кнопки -->
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <!-- Метка -->
                    <ColumnDefinition Width="*"/>
                    <!-- Поле -->
                    <ColumnDefinition Width="120"/>
                    <!-- Метка -->
                    <ColumnDefinition Width="*"/>
                    <!-- Поле -->
                </Grid.ColumnDefinitions>

                <!-- ========== Строка 0: Должность + Отдел ========== -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Должность:" VerticalAlignment="Center" Margin="5,2"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbPosition" 
                          DisplayMemberPath="Title" SelectedValuePath="Id"
                          Margin="5,2" Height="28"
                          SelectionChanged="CmbPosition_SelectionChanged"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Отдел:" VerticalAlignment="Center" Margin="5,2"/>
                <ComboBox Grid.Row="0" Grid.Column="3" x:Name="cmbDepartment" 
                          DisplayMemberPath="Name" SelectedValuePath="Id"
                          Margin="5,2" Height="28"
                          SelectionChanged="CmbDepartment_SelectionChanged"/>

                <!-- ========== Строка 1: Дата приема ========== -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата приема:" VerticalAlignment="Center" Margin="5,2"/>
                <DatePicker Grid.Row="1" Grid.Column="1" x:Name="dpHireDate" 
                            Margin="5,2" Height="28" Width="130" HorizontalAlignment="Left"
                            SelectedDateChanged="DpHireDate_SelectedDateChanged"/>

                <!-- ========== Строка 2: Оклад + Надбавка ========== -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Оклад:" VerticalAlignment="Center" Margin="5,2"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSalary" 
                         Margin="5,2" Height="28"
                         TextChanged="TxtSalary_TextChanged"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Надбавка:" VerticalAlignment="Center" Margin="5,2"/>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="txtAllowance" 
                         Margin="5,2" Height="28"
                         TextChanged="TxtAllowance_TextChanged"/>

                <!-- ========== Строка 3: Итого оклад ========== -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Итого оклад:" VerticalAlignment="Center" Margin="5,2"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="tbTotalSalary" 
                           Style="{StaticResource ReadOnlyTextBlockStyle}" Margin="5,2"/>

                <!-- ========== Строка 4: Ставка + Часы ========== -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Ставка:" VerticalAlignment="Center" Margin="5,2"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbRate" Margin="5,2" Height="28">
                    <ComboBoxItem Content="1.0 (полная ставка)"/>
                    <ComboBoxItem Content="0.75 (3/4 ставки)"/>
                    <ComboBoxItem Content="0.5 (полставки)"/>
                    <ComboBoxItem Content="0.25 (1/4 ставки)"/>
                </ComboBox>
                <TextBlock Grid.Row="4" Grid.Column="2" Text="Часы (в день):" VerticalAlignment="Center" Margin="5,2"/>
                <ComboBox Grid.Row="4" Grid.Column="3" x:Name="cmbHours" Margin="5,2" Height="28">
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="6"/>
                    <ComboBoxItem Content="8" IsSelected="True"/>
                    <ComboBoxItem Content="12"/>
                </ComboBox>

                <!-- ========== Строка 5: Тарифный разряд + Коэффициент ========== -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Тарифный разряд:" VerticalAlignment="Center" Margin="5,2"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtGrade" Margin="5,2" Height="28"/>
                <TextBlock Grid.Row="5" Grid.Column="2" Text="Тарифный коэф.:" VerticalAlignment="Center" Margin="5,2"/>
                <TextBox Grid.Row="5" Grid.Column="3" x:Name="txtCoefficient" Margin="5,2" Height="28" Text="1.0"/>

                <!-- ========== Строка 6: Интенсивность + Контракт ========== -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Повышение за интенсивность:" VerticalAlignment="Center" Margin="5,2"/>
                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="5,2">
                    <TextBox x:Name="txtIntensity" Width="60" Height="28" Text="0" TextAlignment="Right"/>
                    <TextBlock Text=" %" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>
                <TextBlock Grid.Row="6" Grid.Column="2" Text="Повышение за контракт:" VerticalAlignment="Center" Margin="5,2"/>
                <StackPanel Grid.Row="6" Grid.Column="3" Orientation="Horizontal" Margin="5,2">
                    <TextBox x:Name="txtContractPercent" Width="60" Height="28" Text="0" TextAlignment="Right"/>
                    <TextBlock Text=" %" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <!-- ========== Строка 7: Форма занятости + Тип договора ========== -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Форма занятости:" VerticalAlignment="Center" Margin="5,2"/>
                <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cmbEmploymentType" Margin="5,2" Height="28">
                    <ComboBoxItem Content="Основная" IsSelected="True"/>
                    <ComboBoxItem Content="Совместительство"/>
                    <ComboBoxItem Content="Внешнее совместительство"/>
                </ComboBox>
                <TextBlock Grid.Row="7" Grid.Column="2" Text="Тип договора:" VerticalAlignment="Center" Margin="5,2"/>
                <ComboBox Grid.Row="7" Grid.Column="3" x:Name="cmbContractType" Margin="5,2" Height="28"
                          SelectionChanged="CmbContractType_SelectionChanged">
                    <ComboBoxItem Content="01 - Трудовой договор" Tag="01"/>
                    <ComboBoxItem Content="02 - Контракт" Tag="02"/>
                    <ComboBoxItem Content="03 - Договор подряда" Tag="03"/>
                </ComboBox>

                <!-- ========== Строка 8: Срок действия ========== -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Срок действия (до):" VerticalAlignment="Center" Margin="5,2"/>
                <DatePicker Grid.Row="8" Grid.Column="1" x:Name="dpContractEnd" 
                            Margin="5,2" Height="28" Width="130" HorizontalAlignment="Left"/>

                <!-- ========== Строка 9: Стаж работы + Рабочая неделя ========== -->
                <TextBlock Grid.Row="9" Grid.Column="0" Text="Стаж работы:" VerticalAlignment="Center" Margin="5,2"/>
                <TextBlock Grid.Row="9" Grid.Column="1" x:Name="tbExperience" 
                           Style="{StaticResource ReadOnlyTextBlockStyle}" Margin="5,2"/>
                <TextBlock Grid.Row="9" Grid.Column="2" Text="Рабочая неделя:" VerticalAlignment="Center" Margin="5,2"/>
                <ComboBox Grid.Row="9" Grid.Column="3" x:Name="cmbWorkWeek" Margin="5,2" Height="28">
                    <ComboBoxItem Content="5-дневная" IsSelected="True"/>
                    <ComboBoxItem Content="6-дневная"/>
                </ComboBox>

                <!-- ========== Строка 10: Категория + Условия труда ========== -->
                <TextBlock Grid.Row="10" Grid.Column="0" Text="Категория:" VerticalAlignment="Center" Margin="5,2"/>
                <ComboBox Grid.Row="10" Grid.Column="1" x:Name="cmbCategory" Margin="5,2" Height="28">
                    <ComboBoxItem Content="1 - Руководитель"/>
                    <ComboBoxItem Content="2 - Специалист" IsSelected="True"/>
                    <ComboBoxItem Content="3 - Другой служащий"/>
                    <ComboBoxItem Content="4 - Рабочий"/>
                </ComboBox>
                <TextBlock Grid.Row="10" Grid.Column="2" Text="Условия труда:" VerticalAlignment="Center" Margin="5,2"/>
                <ComboBox Grid.Row="10" Grid.Column="3" x:Name="cmbWorkConditions" Margin="5,2" Height="28">
                    <ComboBoxItem Content="Нормальные" IsSelected="True"/>
                    <ComboBoxItem Content="Вредные"/>
                    <ComboBoxItem Content="Тяжелые"/>
                    <ComboBoxItem Content="Особые"/>
                </ComboBox>

                <!-- ========== Строка 11: Пенсионер + Инвалид ========== -->
                <CheckBox Grid.Row="11" Grid.Column="0" x:Name="chkIsPensioner" 
                          Content="Пенсионер" Margin="10,5,5,2" VerticalAlignment="Center"/>
                <CheckBox Grid.Row="11" Grid.Column="2" x:Name="chkIsDisabled" 
                          Content="Инвалид" Margin="10,5,5,2" VerticalAlignment="Center"/>

                <!-- ========== Строка 12: Дата увольнения ========== -->
                <TextBlock Grid.Row="12" Grid.Column="0" Text="Дата увольнения:" VerticalAlignment="Center" Margin="5,2"/>
                <DatePicker Grid.Row="12" Grid.Column="1" x:Name="dpDismissalDate" 
                            Margin="5,2" Height="28" Width="130" HorizontalAlignment="Left"/>

                <!-- ========== Строка 13: Кнопки сохранения ========== -->
                <StackPanel Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="4" 
                            Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,15,5,0">
                    <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="32" 
                            Margin="5" Background="#4CAF50" Foreground="White" Cursor="Hand"
                            Click="BtnSave_Click"/>
                    <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="32" 
                            Margin="5" Cursor="Hand"
                            Click="BtnCancel_Click"/>
                </StackPanel>
            </Grid>

            <!-- ============================================ -->
            <!-- ПРАВАЯ КОЛОНКА (40%)                          -->
            <!-- ============================================ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: Назначения -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1: Повышение/Переподготовка -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2: Аттестация -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3: Доп. сведения -->
                </Grid.RowDefinitions>

                <!-- ========== БЛОК 0: НАЗНАЧЕНИЯ И ПЕРЕМЕЩЕНИЯ ========== -->
                <GroupBox Grid.Row="0" Header="📋 НАЗНАЧЕНИЯ И ПЕРЕМЕЩЕНИЯ" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" x:Name="dgEmploymentHistory" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False" 
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  RowHeight="28"
                                  Margin="0,0,0,5"
                                  SelectionChanged="DgEmploymentHistory_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата" Binding="{Binding AssignmentDate, StringFormat='dd.MM.yyyy'}" Width="80"/>
                                <DataGridTextColumn Header="Отдел" Binding="{Binding DepartmentName}" Width="80"/>
                                <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}" Width="90"/>
                                <DataGridTextColumn Header="Основание" Binding="{Binding OrderNumber}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                            <Button x:Name="btnAddHistory" Content="➕" Style="{StaticResource TableButtonStyle}" 
                                    Click="BtnAddHistory_Click" ToolTip="Добавить запись"/>
                            <Button x:Name="btnEditHistory" Content="✏️" Style="{StaticResource TableButtonStyle}" 
                                    Click="BtnEditHistory_Click" ToolTip="Редактировать"/>
                            <Button x:Name="btnDeleteHistory" Content="🗑️" Style="{StaticResource TableButtonStyle}" 
                                    Click="BtnDeleteHistory_Click" ToolTip="Удалить"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- ========== БЛОК 1: ПОВЫШЕНИЕ КВАЛИФИКАЦИИ / ПЕРЕПОДГОТОВКА ========== -->
                <GroupBox Grid.Row="1" Header="📚 ПОВЫШЕНИЕ КВАЛИФИКАЦИИ / ПЕРЕПОДГОТОВКА" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" x:Name="dgAdvancedTraining" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False" 
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  RowHeight="28"
                                  Margin="0,0,0,5"
                                  SelectionChanged="DgAdvancedTraining_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat='dd.MM.yyyy'}" Width="70"/>
                                <DataGridTextColumn Header="Вид / Специальность" Binding="{Binding Name}" Width="120"/>
                                <DataGridTextColumn Header="Документ" Binding="{Binding DocumentNumber}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                            <Button x:Name="btnAddTraining" Content="➕" Style="{StaticResource TableButtonStyle}" 
                                    Click="BtnAddTraining_Click" ToolTip="Добавить запись"/>
                            <Button x:Name="btnEditTraining" Content="✏️" Style="{StaticResource TableButtonStyle}" 
                                    Click="BtnEditTraining_Click" ToolTip="Редактировать"/>
                            <Button x:Name="btnDeleteTraining" Content="🗑️" Style="{StaticResource TableButtonStyle}" 
                                    Click="BtnDeleteTraining_Click" ToolTip="Удалить"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- ========== БЛОК 2: АТТЕСТАЦИЯ ========== -->
                <GroupBox Grid.Row="2" Header="⭐ АТТЕСТАЦИЯ" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" x:Name="dgCertification" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False" 
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  RowHeight="28"
                                  Margin="0,0,0,5"
                                  SelectionChanged="DgCertification_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat='dd.MM.yyyy'}" Width="70"/>
                                <DataGridTextColumn Header="Решение комиссии" Binding="{Binding Decision}" Width="190"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                            <Button x:Name="btnAddCertification" Content="➕" Style="{StaticResource TableButtonStyle}" 
                                    Click="BtnAddCertification_Click" ToolTip="Добавить запись"/>
                            <Button x:Name="btnEditCertification" Content="✏️" Style="{StaticResource TableButtonStyle}" 
                                    Click="BtnEditCertification_Click" ToolTip="Редактировать"/>
                            <Button x:Name="btnDeleteCertification" Content="🗑️" Style="{StaticResource TableButtonStyle}" 
                                    Click="BtnDeleteCertification_Click" ToolTip="Удалить"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- ========== БЛОК 3: ДОПОЛНИТЕЛЬНЫЕ СВЕДЕНИЯ (ТРУДОУСТРОЙСТВО) ========== -->
                <GroupBox Grid.Row="3" Header="📝 ДОПОЛНИТЕЛЬНЫЕ СВЕДЕНИЯ (по трудовому договору)" Style="{StaticResource GroupBoxStyle}">
                    <TextBox x:Name="txtEmploymentAdditionalInfo" 
             TextWrapping="Wrap" 
             AcceptsReturn="True"
             MinHeight="60"
             MaxHeight="100"
             VerticalScrollBarVisibility="Auto"
             Padding="5"
             TextChanged="TxtEmploymentAdditionalInfo_TextChanged"/>
                </GroupBox>

            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>