<UserControl x:Class="StaffBY.App.Views.UserControls.EmployeeCard.EmploymentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Должность -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Должность:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbPosition" Height="28" Margin="5"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <!-- Отдел -->
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Отдел:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="0" Grid.Column="3" x:Name="cmbDepartment" Height="28" Margin="5"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <!-- Дата приема -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата приема:" VerticalAlignment="Center" Margin="5"/>
        <DatePicker Grid.Row="1" Grid.Column="1" x:Name="dpHireDate" Height="28" Margin="5"/>

        <!-- Оклад -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Оклад:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSalary" Height="28" Margin="5"/>

        <!-- Форма занятости -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Форма занятости:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbEmploymentType" Height="28" Margin="5">
            <ComboBoxItem Content="Основная"/>
            <ComboBoxItem Content="Совместительство"/>
        </ComboBox>

        <!-- Тип договора -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Тип договора:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbContractType" Height="28" Margin="5">
            <ComboBoxItem Content="Трудовой договор"/>
            <ComboBoxItem Content="Контракт"/>
        </ComboBox>

        <!-- Срок действия контракта -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Срок действия:" VerticalAlignment="Center" Margin="5"/>
        <DatePicker Grid.Row="5" Grid.Column="1" x:Name="dpContractEndDate" Height="28" Margin="5"/>

        <!-- Стаж работы -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Стаж работы:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtWorkExperience" Height="28" Margin="5" IsReadOnly="True" Background="#F0F0F0"/>

        <!-- На данном предприятии -->
        <TextBlock Grid.Row="6" Grid.Column="2" Text="На данном предприятии:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="6" Grid.Column="3" x:Name="txtExperienceHere" Height="28" Margin="5" IsReadOnly="True" Background="#F0F0F0"/>
    </Grid>
</UserControl>