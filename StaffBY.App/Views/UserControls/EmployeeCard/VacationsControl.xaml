<UserControl x:Class="StaffBY.App.Views.UserControls.EmployeeCard.VacationsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10,5" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить период отпуска" Padding="8,5" Margin="0,0,5,0"
            Background="#3498DB" Foreground="White" Click="AddVacationRow_Click"/>

                <!-- НОВАЯ КНОПКА -->
                <Button Content="📝 Добавить отпуск в период" Padding="8,5" Margin="5,0"
            Background="#27AE60" Foreground="White" Click="AddVacationToPeriod_Click"/>

                <Button Content="✏️ Редактировать" Padding="8,5" Margin="5,0"
            Background="#F39C12" Foreground="White" Click="EditVacationRow_Click"/>
                <Button Content="🗑️ Удалить" Padding="8,5" Margin="5,0"
            Background="#E74C3C" Foreground="White" Click="DeleteVacationRow_Click"/>
                <TextBlock Text="Остаток отпуска на сегодня:" VerticalAlignment="Center" Margin="30,0,10,0"/>
                <TextBlock x:Name="txtTotalRemaining" Text="0" FontSize="18" FontWeight="Bold" Foreground="#27AE60"/>
                <TextBlock Text="дней" Margin="5,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Таблица отпусков -->
        <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="ТАБЛИЦА ОТПУСКОВ" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                <DataGrid x:Name="dgVacations" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single"
                          CanUserAddRows="False" CanUserDeleteRows="False" AlternatingRowBackground="#F9F9F9" 
                          Height="300" RowHeight="40"
                          MouseDoubleClick="DgVacations_MouseDoubleClick">

                    <DataGrid.Resources>
                        <!-- Единый стиль для всех заголовков с переносом текста -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Height" Value="55"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Background" Value="#34495E"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#2C3E50"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" 
                                                   TextWrapping="Wrap" 
                                                   TextAlignment="Center" 
                                                   Width="Auto"
                                                   Margin="5,3"/>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <!-- Стиль для ячеек -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="5,2"/>
                            <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Период начало" 
                                            Binding="{Binding PeriodStart, StringFormat=dd.MM.yyyy}" 
                                            IsReadOnly="True" 
                                            Width="100"/>

                        <DataGridTextColumn Header="Период окончание" 
                                            Binding="{Binding PeriodEnd, StringFormat=dd.MM.yyyy}" 
                                            IsReadOnly="True" 
                                            Width="100"/>

                        <DataGridTextColumn Header="Предоставляется отпуск с" 
                                            Binding="{Binding AvailableFrom, StringFormat=dd.MM.yyyy}" 
                                            IsReadOnly="True" 
                                            Width="130"/>

                        <DataGridTextColumn Header="Основной отпуск" 
                                            Binding="{Binding BasicDays}" 
                                            IsReadOnly="True" 
                                            Width="90"/>

                        <DataGridTextColumn Header="Дополнительный отпуск" 
                                            Binding="{Binding AdditionalDays}" 
                                            IsReadOnly="True" 
                                            Width="110"/>

                        <DataGridTextColumn Header="Всего дней в отпуске" 
                                            Binding="{Binding TotalDays}" 
                                            IsReadOnly="True" 
                                            Width="100"/>

                        <DataGridTextColumn Header="Использовано дней" 
                                            Binding="{Binding UsedDays, UpdateSourceTrigger=PropertyChanged}" 
                                            Width="100"/>

                        <DataGridTemplateColumn Header="Дата начала отпуска" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StartDate, StringFormat=dd.MM.yyyy}" 
                                               TextAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <DatePicker SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}" 
                                                SelectedDateChanged="VacationStartDateChanged"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Дата окончания отпуска" 
                                            Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" 
                                            IsReadOnly="True" 
                                            Width="120"/>

                        <DataGridTextColumn Header="Основание (приказ)" 
                                            Binding="{Binding Basis, UpdateSourceTrigger=PropertyChanged}" 
                                            Width="150"/>

                        <DataGridTextColumn Header="График отпусков" 
                                            Binding="{Binding Schedule}" 
                                            IsReadOnly="True" 
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Архив -->
        <Expander Grid.Row="2" Header="▶ АРХИВ" Margin="0,0,0,10" IsExpanded="False">
            <Border BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,5,0,0">
                <DataGrid x:Name="dgVacationsArchive" AutoGenerateColumns="False" IsReadOnly="True" Height="150">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Период" Binding="{Binding PeriodName}" Width="100"/>
                        <DataGridTextColumn Header="Всего" Binding="{Binding TotalDays}" Width="60"/>
                        <DataGridTextColumn Header="Использовано" Binding="{Binding UsedDays}" Width="80"/>
                        <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Остаток" Binding="{Binding RemainingDays}" Width="60"/>
                        <DataGridTextColumn Header="Основание" Binding="{Binding Basis}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Expander>

        <!-- Нормы отпусков -->
        <Border Grid.Row="3" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10">
            <StackPanel>
                <TextBlock Text="НОРМЫ ОТПУСКОВ ЗА ГОД" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Основной отпуск:"/>
                    <TextBlock Grid.Column="1" x:Name="txtBasicNorm" Text="24" FontWeight="Bold" Margin="5,0,5,0"/>
                    <TextBlock Grid.Column="2" Text="дней" Margin="0,0,20,0"/>
                    <TextBlock Grid.Column="3" Text="Дополнительный отпуск (всего):"/>
                    <TextBlock Grid.Column="4" x:Name="txtTotalAdditional" Text="0" FontWeight="Bold" Foreground="#27AE60" Margin="5,0,5,0"/>
                    <TextBlock Grid.Column="5" Text="дней"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,5">
                    <Border BorderBrush="#BDC3C7" BorderThickness="1" Padding="8,3" Margin="0,0,15,0" MinWidth="110">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="за контракт:" FontSize="11" TextWrapping="Wrap" MaxWidth="70"/>
                            <TextBox Grid.Column="1" x:Name="txtContractDays" Width="45" Text="0"
                                     TextAlignment="Center" TextChanged="AdditionalVacation_TextChanged" FontSize="11" Margin="5,0"/>
                            <TextBlock Grid.Column="2" Text="дн." FontSize="11"/>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#BDC3C7" BorderThickness="1" Padding="8,3" Margin="0,0,15,0" MinWidth="110">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="за вредность:" FontSize="11" TextWrapping="Wrap" MaxWidth="70"/>
                            <TextBox Grid.Column="1" x:Name="txtHarmfulDays" Width="45" Text="0"
                                     TextAlignment="Center" TextChanged="AdditionalVacation_TextChanged" FontSize="11" Margin="5,0"/>
                            <TextBlock Grid.Column="2" Text="дн." FontSize="11"/>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#BDC3C7" BorderThickness="1" Padding="8,3" Margin="0,0,15,0" MinWidth="110">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ненормир. день:" FontSize="11" TextWrapping="Wrap" MaxWidth="70"/>
                            <TextBox Grid.Column="1" x:Name="txtIrregularDays" Width="45" Text="0"
                                     TextAlignment="Center" TextChanged="AdditionalVacation_TextChanged" FontSize="11" Margin="5,0"/>
                            <TextBlock Grid.Column="2" Text="дн." FontSize="11"/>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#BDC3C7" BorderThickness="1" Padding="8,3" Margin="0,0,15,0" MinWidth="110">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="за стаж:" FontSize="11" TextWrapping="Wrap" MaxWidth="70"/>
                            <TextBox Grid.Column="1" x:Name="txtExperienceDays" Width="45" Text="0"
                                     TextAlignment="Center" TextChanged="AdditionalVacation_TextChanged" FontSize="11" Margin="5,0"/>
                            <TextBlock Grid.Column="2" Text="дн." FontSize="11"/>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#BDC3C7" BorderThickness="1" Padding="8,3" Margin="0,0,15,0" MinWidth="110">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="поощрительный:" FontSize="11" TextWrapping="Wrap" MaxWidth="70"/>
                            <TextBox Grid.Column="1" x:Name="txtBonusDays" Width="45" Text="0"
                                     TextAlignment="Center" TextChanged="AdditionalVacation_TextChanged" FontSize="11" Margin="5,0"/>
                            <TextBlock Grid.Column="2" Text="дн." FontSize="11"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ВСЕГО отпуск за год:" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Grid.Column="1" x:Name="txtTotalYear" Text="24" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" Margin="10,0,5,0"/>
                    <TextBlock Grid.Column="2" Text="дней"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>