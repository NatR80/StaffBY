<UserControl x:Class="StaffBY.App.Views.UserControls.PositionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Штатное расписание" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"
                   Foreground="#2C3E50"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="➕ Добавить должность" Padding="10,5" Margin="5"
                    Background="#27AE60" Foreground="White" Click="AddPositionButton_Click"/>
            <Button Content="✏️ Редактировать" Padding="10,5" Margin="5"
                    Background="#3498DB" Foreground="White" Click="EditPositionButton_Click"/>
            <Button Content="🗑️ Удалить" Padding="10,5" Margin="5"
                    Background="#E74C3C" Foreground="White" Click="DeletePositionButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="PositionsDataGrid" Grid.Row="2" AutoGenerateColumns="False"
                  SelectionMode="Single" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Должность" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding DepartmentName}" Width="150"/>
                <DataGridTextColumn Header="Количество ставок" Binding="{Binding NumberOfPositions}" Width="120"/>
                <DataGridTextColumn Header="Оклад (руб.)" Binding="{Binding Salary, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Надбавка (руб.)" Binding="{Binding Allowance, StringFormat=N2}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>