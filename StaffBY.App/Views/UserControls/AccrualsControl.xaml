<UserControl x:Class="StaffBY.App.Views.UserControls.AccrualsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Расчет начислений заработной платы" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15"
                   Foreground="#2C3E50"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpStart" Width="120" Margin="0,0,10,0"/>
            <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpEnd" Width="120" Margin="0,0,10,0"/>
            <Button Content="🧮 Рассчитать начисления" Padding="10,5"
                    Background="#3498DB" Foreground="White" Click="CalculateButton_Click"/>
            <Button Content="📤 Экспорт в Excel" Padding="10,5" Margin="10,0,0,0"
                    Background="#27AE60" Foreground="White" Click="ExportButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Сводка по начислениям" FontWeight="Bold" Margin="0,5,0,5"/>

        <DataGrid x:Name="AccrualsDataGrid" Grid.Row="3" AutoGenerateColumns="False"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Табельный номер" Binding="{Binding PersonalNumber}" Width="100"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding FullName}" Width="150"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}" Width="150"/>
                <DataGridTextColumn Header="Оклад" Binding="{Binding Salary, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Отработано дней" Binding="{Binding WorkedDays}" Width="120"/>
                <DataGridTextColumn Header="Начислено (руб.)" Binding="{Binding AccruedAmount, StringFormat=N2}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>