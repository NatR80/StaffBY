<UserControl x:Class="StaffBY.App.Views.UserControls.TimesheetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Табель учета рабочего времени" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"
                   Foreground="#2C3E50"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpStart" Width="120" Margin="0,0,10,0"/>
            <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpEnd" Width="120" Margin="0,0,10,0"/>
            <Button Content="📊 Сформировать табель" Padding="10,5"
                    Background="#3498DB" Foreground="White" Click="GenerateButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Учет рабочего времени" FontWeight="Bold" Margin="0,10,0,5"/>

        <DataGrid x:Name="TimesheetDataGrid" Grid.Row="3" AutoGenerateColumns="False"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Табельный номер" Binding="{Binding PersonalNumber}" Width="100"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding FullName}" Width="150"/>
                <DataGridTextColumn Header="Отработано дней" Binding="{Binding WorkedDays}" Width="120"/>
                <DataGridTextColumn Header="Больничные" Binding="{Binding SickDays}" Width="100"/>
                <DataGridTextColumn Header="Отпуск" Binding="{Binding VacationDays}" Width="100"/>
                <DataGridTextColumn Header="Прогулы" Binding="{Binding AbsentDays}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>