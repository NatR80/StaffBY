<UserControl x:Class="StaffBY.App.Views.UserControls.EmployeesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление сотрудниками" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"
                   Foreground="#2C3E50"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="SearchTextBox" 
                     Width="250" 
                     Padding="8"
                     ToolTip="Поиск по ФИО или табельному номеру"
                     TextChanged="SearchTextBox_TextChanged"/>
            <Button Content="🔍 Поиск" 
                    Padding="10,5" Margin="5"
                    Background="#3498DB" Foreground="White"
                    Click="SearchButton_Click"/>
            <Button Content="➕ Добавить сотрудника" 
                    Padding="10,5" Margin="5"
                    Background="#27AE60" Foreground="White"
                    Click="AddEmployeeButton_Click"/>
            <Button Content="📊 Экспорт в Excel" 
                    Padding="10,5" Margin="5"
                    Background="#3498DB" Foreground="White"
                    Click="ExportToExcelButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="EmployeesDataGrid" 
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  MouseDoubleClick="EmployeesDataGrid_MouseDoubleClick"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Табельный номер" Binding="{Binding PersonalNumber}" Width="100"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="100"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}" Width="150"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding DepartmentName}" Width="150"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Оклад" Binding="{Binding Salary, StringFormat=N2}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>