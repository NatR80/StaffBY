<UserControl x:Class="StaffBY.App.Views.UserControls.ArchiveControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Уволенные сотрудники" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"
                   Foreground="#2C3E50"/>

        <DataGrid x:Name="ArchiveDataGrid" Grid.Row="1" AutoGenerateColumns="False"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Табельный номер" Binding="{Binding PersonalNumber}" Width="100"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}" Width="150"/>
                <DataGridTextColumn Header="Дата увольнения" Binding="{Binding DismissalDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                <DataGridTextColumn Header="Причина" Binding="{Binding DismissalReason}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>