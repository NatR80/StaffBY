<Window x:Class="StaffBY.App.Views.PositionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Должность" Width="450" Height="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Данные должности" 
                   FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Подразделение:" Margin="5"/>
        <ComboBox x:Name="cmbDepartment" Grid.Row="1" Grid.Column="1" Margin="5" 
          IsEditable="True" IsTextSearchEnabled="True"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Должность:" Margin="5"/>
        <TextBox x:Name="txtName" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Штатных единиц:" Margin="5"/>
        <TextBox x:Name="txtStaffUnits" Grid.Row="3" Grid.Column="1" Margin="5" Text="1"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ставка:" Margin="5"/>
        <ComboBox x:Name="cmbRate" Grid.Row="4" Grid.Column="1" Margin="5" SelectedIndex="3">
            <ComboBoxItem Content="0.25"/>
            <ComboBoxItem Content="0.5"/>
            <ComboBoxItem Content="0.75"/>
            <ComboBoxItem Content="1.0"/>
        </ComboBox>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Рабочая неделя:" Margin="5"/>
        <ComboBox x:Name="cmbWorkWeek" Grid.Row="5" Grid.Column="1" Margin="5" SelectedIndex="0">
            <ComboBoxItem Content="5-дневная"/>
            <ComboBoxItem Content="6-дневная"/>
            <ComboBoxItem Content="Сменная"/>
        </ComboBox>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Категория:" Margin="5"/>
        <ComboBox x:Name="cmbCategory" Grid.Row="6" Grid.Column="1" Margin="5" SelectedIndex="1">
            <ComboBoxItem Content="Руководитель"/>
            <ComboBoxItem Content="Специалист"/>
            <ComboBoxItem Content="Служащий"/>
            <ComboBoxItem Content="Рабочий"/>
        </ComboBox>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Оклад (руб.):" Margin="5"/>
        <TextBox x:Name="txtSalary" Grid.Row="7" Grid.Column="1" Margin="5" Text="0"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Надбавка (руб.):" Margin="5"/>
        <TextBox x:Name="txtAllowance" Grid.Row="8" Grid.Column="1" Margin="5" Text="0"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="5">
            <Button Content="Сохранить" Width="80" Margin="5" Click="Save_Click"
                    Background="#27AE60" Foreground="White"/>
            <Button Content="Отмена" Width="80" Margin="5" Click="Cancel_Click"
                    Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>