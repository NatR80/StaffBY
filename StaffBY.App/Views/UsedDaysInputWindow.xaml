<Window x:Class="StaffBY.App.Views.UsedDaysInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📝 Ввод использованных дней отпуска"
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация о периоде -->
        <Border Grid.Row="0" Background="#ECF0F1" CornerRadius="5" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Период отпуска:" FontWeight="Bold"/>
                <TextBlock x:Name="txtPeriodInfo" FontSize="14" Margin="0,5,0,0"/>
                <TextBlock Text="Остаток дней:" FontWeight="Bold" Margin="0,10,0,0"/>
                <TextBlock x:Name="txtRemainingDays" FontSize="16" FontWeight="Bold" Foreground="#27AE60"/>
            </StackPanel>
        </Border>

        <!-- Количество дней -->
        <TextBlock Grid.Row="1" Text="Количество использованных дней:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox Grid.Row="2" x:Name="txtDaysCount" Height="35" FontSize="14" 
                 PreviewTextInput="NumberValidationTextBox" Margin="0,0,0,15"/>

        <!-- Дата начала отпуска -->
        <TextBlock Grid.Row="3" Text="Дата начала отпуска:" FontWeight="Bold" Margin="0,5,0,5"/>
        <DatePicker Grid.Row="4" x:Name="dpStartDate" Height="35" Margin="0,0,0,15"/>

        <!-- Основание (приказ) -->
        <TextBlock Grid.Row="5" Text="Основание (приказ):" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox Grid.Row="6" x:Name="txtBasis" Height="35" Margin="0,0,0,15"
                 ToolTip="Например: Приказ №123 от 01.06.2026"/>

        <!-- Пояснение о законодательстве -->
        <Border Grid.Row="7" Background="#FFF3CD" CornerRadius="5" Padding="10" Margin="0,10,0,10">
            <TextBlock Text="⚠️ Важно: Согласно законодательству, одна часть отпуска должна быть не менее 14 календарных дней."
                       FontSize="11" Foreground="#856404" TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="💾 Сохранить" Width="100" Height="35" Margin="5"
                    Background="#27AE60" Foreground="White" Click="SaveButton_Click"/>
            <Button Content="❌ Отмена" Width="100" Height="35" Margin="5"
                    Background="#95A5A6" Foreground="White" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>